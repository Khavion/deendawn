# Copy to .env (gitignored). Never commit real values.

# --- Expo account access token (lets EAS builds run headless, no browser login) ---
# Create a free account at expo.dev, then expo.dev > Account Settings > Access
# Tokens > Create. Paste it here so `eas build`/`eas submit` run non-interactively.
EXPO_TOKEN=

# --- Apple / App Store Connect API key (for headless `eas submit`) ---
# The constitution's canonical names:
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_KEY_PATH=
# EAS Submit auto-detects the EXPO_-prefixed names below. Set these to the SAME
# values as the three above so `eas submit -p ios --profile production` runs
# headless with no prompts. (Only needed at submit time, which is a Human Gate.)
EXPO_ASC_KEY_ID=
EXPO_ASC_ISSUER_ID=
EXPO_ASC_API_KEY_PATH=

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
REVENUECAT_IOS_KEY=
